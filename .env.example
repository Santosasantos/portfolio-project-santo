# Supabase (optional — the site falls back to lib/data/portfolio-data.ts when unset)
# 1. Create a project at https://supabase.com/dashboard
# 2. Run supabase/schema.sql then supabase/seed.sql in the SQL Editor
# 3. Copy this file to .env.local and fill in the values from
#    Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
